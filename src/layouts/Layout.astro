---
import "../styles/global.css";
import Head, { type Props as HeadProps } from "@/components/Head.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import SearchModal from "@/components/SearchModal.astro";

export interface Props extends HeadProps {}

const { ...headProps } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <Head {...headProps} />
  </head>
  <body class="flex min-h-screen flex-col dark:bg-neutral-900">
    <Header />
    <div class="flex-1">
      <slot />
    </div>
    <Footer />
    <SearchModal />
    <script
      is:inline
      src="https://cdn.jsdelivr.net/npm/flowbite@4.0.1/dist/flowbite.min.js"
    ></script>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
    overflow-x: hidden;
  }
</style>
