---
interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<h1
  class="text-2xl font-extrabold tracking-tight text-gray-900 dark:text-white"
>
  {title}
</h1>
{
  description && (
    <p class="mt-2 text-gray-500 sm:text-lg dark:text-neutral-400">
      {description}
    </p>
  )
}
