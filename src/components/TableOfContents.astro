---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;
const filtered = headings.filter((h) => h.depth >= 1 && h.depth <= 3);
---

{
  filtered.length > 0 && (
    <nav class="sticky top-24">
      <p class="mb-3 text-xs font-semibold tracking-wide text-gray-900 uppercase dark:text-white">
        On this page
      </p>
      <ul class="space-y-1">
        {filtered.map((heading) => (
          <li>
            <a
              href={`#${heading.slug}`}
              class:list={[
                "toc-link block py-1 text-sm text-gray-500 transition-colors hover:text-amber-600 dark:text-neutral-400",
                { "pl-3": heading.depth === 2 },
                { "pl-6": heading.depth === 3 },
              ]}
              data-slug={heading.slug}
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}

<script>
  let observer: IntersectionObserver | null = null;

  function initToc() {
    observer?.disconnect();

    const links = document.querySelectorAll<HTMLAnchorElement>(".toc-link");
    if (links.length === 0) return;

    const headingElements = Array.from(links)
      .map((link) => document.getElementById(link.dataset.slug!))
      .filter(Boolean) as HTMLElement[];

    if (headingElements.length === 0) return;

    function setActive(slug: string) {
      links.forEach((link) => {
        const isActive = link.dataset.slug === slug;
        link.classList.toggle("text-gray-500", !isActive);
        link.classList.toggle("dark:text-neutral-400", !isActive);
        link.classList.toggle("text-amber-600", isActive);
        link.classList.toggle("font-medium", isActive);
      });
    }

    observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            setActive(entry.target.id);
          }
        }
      },
      { rootMargin: "0px 0px -70% 0px" },
    );

    headingElements.forEach((el) => observer!.observe(el));
  }

  initToc();
  document.addEventListener("astro:after-swap", initToc);
</script>
