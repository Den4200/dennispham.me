---
import { Image } from "astro:assets";
import Layout from "@/layouts/Layout.astro";
import PhotoCard from "@/components/PhotoCard.astro";
import GitHubIcon from "@/components/GitHubIcon.astro";
import { getPublishedPosts } from "@/lib/posts";
import { formatDate } from "@/lib/format-date";
import { projects } from "@/lib/projects";
import { tracks } from "@/lib/guitar";
import { getAlbum } from "@/lib/immich";
import GuitarPlayer from "@/components/GuitarPlayer.astro";

const posts = (await getPublishedPosts()).slice(0, 3);
const featuredProjects = projects.slice(0, 4);

const album = await getAlbum();
const photos = [...album.assets].sort(() => Math.random() - 0.5).slice(0, 8);
---

<Layout>
  <main class="mx-auto max-w-7xl px-4 py-16 lg:px-6 lg:py-24">
    <div class="flex flex-col items-center gap-8 md:flex-row md:gap-12">
      <!-- Photo -->
      <Image
        src="/dennis.jpg"
        alt="Dennis Pham"
        width={180}
        height={180}
        class="rounded-full bg-gray-200 text-transparent dark:bg-neutral-700"
      />

      <!-- Intro -->
      <div class="flex-1">
        <h1
          class="text-center text-3xl font-bold text-gray-900 md:text-left lg:text-4xl dark:text-white"
        >
          Hey, I'm Dennis.
        </h1>
        <p class="text-md mt-4 text-gray-700 dark:text-neutral-300">
          I'm the Platform Engineering Lead for the Catalyst Platform at
          Rolls-Royce, based in Philadelphia. I build the internal developer
          platform and tooling that engineers and users across the organization
          rely on every day.
        </p>
        <p class="text-md mt-3 text-gray-700 dark:text-neutral-300">
          Outside of work, I've spent the past 7+ years running <a
            href="https://axolotl.cloud"
            target="_blank"
            rel="noopener noreferrer"
            class="link">Axolotl Cloud</a
          >, a Kubernetes homelab that has been continuously rebuilt and
          rearchitected over the years. <a
            href="https://docs.axolotl.cloud"
            target="_blank"
            rel="noopener noreferrer"
            class="link">Public docs</a
          > are available if you're interested. I also have a 3D printer for making
          and prototyping!
        </p>
        <p class="text-md mt-3 text-gray-700 dark:text-neutral-300">
          When I'm not in front of a keyboard, I enjoy cooking, baking, hiking,
          woodworking, traveling, and photography with my Sony A7C II. I've also
          been playing fingerstyle acoustic guitar for nearly a decade, and have
          recently started exploring electric.
        </p>
        <div class="mt-6 flex flex-wrap justify-center gap-4 md:justify-start">
          <a
            href="/blog/"
            class="rounded-lg bg-amber-600 px-5 py-2.5 text-sm font-medium text-white transition-all duration-150 hover:bg-black dark:hover:bg-white dark:hover:text-neutral-900"
          >
            Read the blog
          </a>
          <a
            href="/about/"
            class="rounded-lg border border-gray-300 px-5 py-2.5 text-sm font-medium text-gray-700 hover:bg-gray-50 dark:border-neutral-600 dark:text-neutral-300 dark:hover:bg-neutral-800"
          >
            About me
          </a>
        </div>
      </div>
    </div>

    <!-- Recent Posts -->
    <section class="mt-16 lg:mt-24">
      <div class="flex items-center justify-between">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white">
          Recent posts
        </h2>
        <a
          href="/blog/"
          class="text-sm font-medium text-gray-500 hover:text-amber-600 dark:text-neutral-400"
        >
          View all &rarr;
        </a>
      </div>
      <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          posts.map((post) => (
            <a
              href={`/blog/${post.id}/`}
              class="rounded-lg border border-gray-200 px-5 pt-3 pb-5 transition-colors hover:border-amber-600 dark:border-neutral-700"
            >
              <time
                datetime={post.data.date.toISOString()}
                class="text-sm text-gray-500 dark:text-neutral-500"
              >
                {formatDate(post.data.date)}
              </time>
              <h3 class="mt-2 text-lg font-semibold text-gray-900 dark:text-white">
                {post.data.title}
              </h3>
              <p class="mt-2 text-sm text-gray-500 dark:text-neutral-400">
                {post.data.description}
              </p>
            </a>
          ))
        }
      </div>
    </section>

    <!-- Projects -->
    <section class="mt-16 lg:mt-24">
      <div class="flex items-center justify-between">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white">
          Projects
        </h2>
        <a
          href="/projects/"
          class="text-sm font-medium text-gray-500 hover:text-amber-600 dark:text-neutral-400"
        >
          View all &rarr;
        </a>
      </div>
      <div class="mt-6 grid auto-rows-fr gap-6 sm:grid-cols-2">
        {
          featuredProjects.map((project) => (
            <div class="flex flex-col rounded-lg border border-gray-200 p-5 dark:border-neutral-700">
              <div class="flex items-start justify-between gap-4">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
                  <a
                    href={project.url || project.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="hover:underline hover:decoration-amber-600"
                  >
                    {project.name}
                  </a>
                </h3>
                <div class="flex shrink-0 items-center gap-3">
                  <a
                    href={project.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="icon-link"
                    aria-label={`${project.name} GitHub repository`}
                  >
                    <GitHubIcon />
                  </a>
                  {project.url && (
                    <a
                      href={project.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-gray-500 hover:text-amber-600 dark:text-neutral-400"
                      aria-label={`${project.name} live site`}
                    >
                      <svg
                        class="h-5 w-5"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        viewBox="0 0 24 24"
                        xmlns="http://www.w3.org/2000/svg"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"
                        />
                      </svg>
                    </a>
                  )}
                </div>
              </div>
              <p class="mt-2 flex-1 text-sm text-gray-500 dark:text-neutral-400">
                {project.description}
              </p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Guitar -->
    <section class="mt-16 lg:mt-24">
      <div class="flex items-center justify-between">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Guitar</h2>
        <a
          href="/guitar/"
          class="text-sm font-medium text-gray-500 hover:text-amber-600 dark:text-neutral-400"
        >
          View all &rarr;
        </a>
      </div>
      <div class="mt-6">
        <GuitarPlayer tracks={tracks} horizontal />
      </div>
    </section>

    <!-- Photos -->
    <section class="mt-16 lg:mt-24">
      <div class="flex items-center justify-between">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Photos</h2>
        <a
          href="/photos/"
          class="text-sm font-medium text-gray-500 hover:text-amber-600 dark:text-neutral-400"
        >
          View all &rarr;
        </a>
      </div>
      <div class="mt-6 columns-1 gap-2 sm:columns-2 lg:columns-3">
        {photos.map((asset) => <PhotoCard asset={asset} />)}
        <a
          href="/photos/"
          class="mb-2 flex aspect-3/2 items-center justify-center rounded bg-gray-100 text-gray-500 hover:bg-gray-200 hover:text-amber-600 dark:bg-neutral-800 dark:text-neutral-400 dark:hover:bg-neutral-700"
        >
          <span class="text-sm font-medium">View more &rarr;</span>
        </a>
      </div>
    </section>
  </main>
</Layout>
